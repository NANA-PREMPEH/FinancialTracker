# Flask
FLASK_ENV=development
SECRET_KEY=change-me-to-a-random-secret

# Database
DATABASE_URL=mysql+pymysql://root:root@localhost/fintrackdb

# Flask-Mail
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=noreply@fintracker.app

# Web Push (VAPID)
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:admin@fintracker.app

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
